{
  "expo": {
    "name": "All AI Tool",
    "slug": "allaitool",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0D0D0D",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.allaitool.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "All AI Tool needs microphone access for voice notes.",
        "NSPhotoLibraryUsageDescription": "All AI Tool needs photo access to organize your screenshots."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.allaitool.app",
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "All AI Tool needs microphone access for voice notes."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "All AI Tool needs camera access to scan screenshots."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "All AI Tool needs photo access to organize your screenshots."
        }
      ]
    ]
  }
}
